# Unreal Engine generated artifacts (patterns have no leading slash, so they match
# at any depth -- this also covers Plugins/*/Binaries, Plugins/*/Intermediate, etc.)
Binaries/
DerivedDataCache/
Intermediate/
Saved/

# Release bundle staging area (per-release framecore-vX.Y.Z/ subdir + zip)
build/

# IDE / build
.vs/
.vscode/
.idea/
.codex/
.cursor/
*.sln
*.suo
*.user
*.VC.db
*.opensdf
*.opendb
*.sdf

# Standalone C++ console-gate build artifacts (FrameCore frame_cli/frametest/frame_perf)
*.exe
*.obj
*.dll
*.lib
*.exp
obj/
obj_cli/
obj_perf/
obj_capi/
obj_capi_v2/
obj_linear_audit/

# Python
__pycache__/
*.pyc

# Local agent / audit transcripts + scratch
*.transcript
*.jsonl
output/
_audit*.log
_scratch*.log
dist/
out/
framecore-v*.zip

# OS cruft
Desktop.ini
Thumbs.db
.DS_Store

# Note: ArchSim.uproject's EngineAssociation is the absolute path of this local
# source/unregistered UE build (E:/project/UE_5.7). That is expected for a local
# engine; to make the project portable, register the engine and use its GUID.
